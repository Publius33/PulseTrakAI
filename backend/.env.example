# Copy to .env and fill values for production
API_KEY=replace-with-a-secure-random-string
DB_PATH=./data.db
# Optional: payment provider secret (Stripe)
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Admin credentials for issuing JWTs in demo (change in production)
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_JWT_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-strong-random-token

STRIPE_WEBHOOK_SECRET=

# Stage 5 ML Scheduler Configuration
ENABLE_SCHEDULER=1
# Anomaly rate threshold for triggering retraining (0.0-1.0)
ANOMALY_THRESHOLD=0.15
# Retraining interval in days (default 7)
RETRAIN_INTERVAL_DAYS=7
# Max versions to keep in model registry (default 3)
MAX_MODEL_VERSIONS=3
# Model backup retention in days (default 30)
MODEL_BACKUP_RETENTION_DAYS=30
